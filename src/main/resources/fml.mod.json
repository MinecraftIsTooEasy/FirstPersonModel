{
  "schemaVersion": 1,
  "id": "first_person_model",
  "version": "${version}",
  "name": "First Person Model mod",
  "description": "Renders player model in first person!",
  "authors": [
    "vbonedra"
  ],
  "contact": {
    "homepage": "https://minecraftistooeasy.github.io/",
    "sources": "https://github.com/MinecraftIsTooEasy/fish-example-mod"
  },
  "license": "CC0-1.0",
  "icon": "assets/first_person_model/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "vbonedra.first_person_model.FirstPersonModelMod"
    ],
    "registry": [
      "vbonedra.first_person_model.register.FirstPersonModelRegistryInit"
    ]
  },
  "mixins": [
    "first_person_model.mixins.json"
  ],
  "depends": {
    "fishmodloader": ">=3.4.0",
    "minecraft": "1.6.4-mite",
    "java": ">=17",
    "many-lib": ">=2.0.0",
    "rusted_iron_core": ">=1.3.5"
  },
  "suggests": {
    "another-mod": "*"
  },
  "accessWidener": "first_person_model.accesswidener",
  "custom": {
    "modmenu:clientsideOnly": true
  }
}